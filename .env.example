PORT=5000
DB_URL=mongodb+srv://example_db_username:example_db_password@cluster0.***.mongodb.net/example_db?retryWrites=true&w=majority&appName=Cluster0
NODE_ENV=development

# bcrypt
SALT='INTEGER' 

# JWT
JWT_SECRET=example_secret_key
JWT_EXPIRESIN=example_duration
REFRESH_JWT_SECRET=example_refresh_secret_key
REFRESH_JWT_EXPIRESIN=example_long_duration

# Super Admin
SUPER_ADMIN_EMAIL=example@mail.com
SUPER_ADMIN_PASSWORD=example_Password

# Google Authentication
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=example_callback_url

# Express Session
EXPRESS_SESSION_SECRET=example_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173